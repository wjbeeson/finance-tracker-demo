{
  "mcpServers": {
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "C:/Users/Will_JetBrains/PycharmProjects/finance-tracker-demo"
      ]
    },
    "mcp-atlassian": {
      "command": "uvx",
      "args": [
        "mcp-atlassian",
        "--jira-url", "${JIRA_URL}",
        "--jira-username", "${JIRA_USERNAME}",
        "--jira-token", "${JIRA_API_TOKEN}"
      ]
    },
    "web-search": {
        "command": "uvx",
        "args": ["duckduckgo-mcp-server"]
    }
  }
}