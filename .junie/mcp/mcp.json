{
  "mcpServers": {
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "C:/Users/Will_JetBrains/PycharmProjects/finance-tracker-demo"
      ]
    },
    "mcp-atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"]
    },
    "web-search": {
        "command": "uvx",
        "args": ["duckduckgo-mcp-server"]
    },
    "github": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_KEY}"
      }
    }
  }
}